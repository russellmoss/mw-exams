  "guardrails": {
    "sweet_flights": {
      "S1_mechanism_diversity": {
        "rule": "Minimum distinct mechanisms by flight size",
        "thresholds": {
          "2_wines": 1,
          "3_wines": 2,
          "4_wines": 3,
          "5_wines": 4,
          "6_wines": 5
        }
      },
      "S2_no_same_mechanism_same_variety": {
        "rule": "Never pair two wines sharing BOTH the same mechanism AND the same variety in a mechanism-testing question"
      },
      "S3_price_ratio_limit": {
        "rule": "Maximum price ratio between most and least expensive sweet wine",
        "max_ratio": 20,
        "note": "A $500 TBA is acceptable alongside a $25 Spatlese; a $3000 TBA alongside a $15 Moscato is not"
      },
      "S4_sweetness_spectrum": {
        "rule": "Include at least 3 different sweetness levels in a 5-wine flight",
        "levels": ["off_dry_10_30gl", "medium_sweet_30_80gl", "sweet_80_150gl", "luscious_150plus_gl", "fortified_sweet"]
      },
      "S5_variety_diversity": {
        "rule": "In mechanism-breadth questions, all varieties should be distinct",
        "exception": "Same-variety questions (F1d) may repeat variety"
      }
    },
    "general": {
      "G1_variety_repetition": {
        "rule": "Variety repetition within a question must be intentional and stem-justified",
        "allowed_in": ["F1_same_variety_questions"],
        "limited_in": ["F5_F6_method_questions_max_1_repeat"],
        "forbidden_in": ["F4_mixed_identification"]
      },
      "G2_price_tier_balance": {
        "rule": "No more than 2 wines from same tier in 4+ wine flight",
        "luxury_constraint": "Max 1 luxury wine (>$200) per question"
      },
      "G3_country_diversity": {
        "targets_by_flight_size": {
          "2_wines": "2 countries unless same-origin",
          "3_wines": "2-3 countries",
          "4_wines": "3-4 countries unless same-origin",
          "5_wines": "4-5 countries unless same-origin",
          "6_wines": "5-6 countries unless same-origin"
        }
      },
      "G4_curveball_budget": {
        "per_question_max": 1,
        "per_paper_max": 2
      }
    },
    "mechanism_taxonomy": {
      "distinct_mechanisms": [
        "ice_wine",
